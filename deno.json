{
  "fmt": {
    "lineWidth": 120,
    "semiColons": false,
    "singleQuote": true,
    "trailingCommas": "onlyMultiLine"
  },
  "imports": {
    "@db/postgres": "jsr:@db/postgres@^0.19.5",
    "@db/sqlite": "jsr:@db/sqlite@^0.13.0",
    "@modelcontextprotocol/sdk": "npm:@modelcontextprotocol/sdk@^1.29.0",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/fs": "jsr:@std/fs@^1.0.23",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@std/toml": "jsr:@std/toml@^1.0.11",
    "zod": "npm:zod@^4.3.6"
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  },
  "tasks": {
    "check": "deno check src/srv.ts",
    "format": "deno fmt",
    "format:check": "deno fmt --check",
    "lint": "deno lint",
    "start": "deno run --allow-all --watch src/srv.ts",
    "start:systemd": "bash .systemd/user.sh up",
    "stop:systemd": "bash .systemd/user.sh down",
    "test": "PRUNUS_ENV=test deno test --allow-all"
  }
}
